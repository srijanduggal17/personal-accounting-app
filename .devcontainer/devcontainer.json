{
    "name": "Ubuntu + PlantUML + Node.js",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "jebbs.plantuml",
                "dbaeumer.vscode-eslint",
                "mtxr.sqltools",
                "qwtel.sqlite-viewer"
            ],
            "settings": {
                "plantuml.jar": "/usr/local/bin/plantuml.jar",
                "plantuml.render": "Local"
            }
        }
    },
    "forwardPorts": [
        3000,
        5173
    ],
    "remoteUser": "root"
}